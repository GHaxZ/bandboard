# Optional: gate the app behind a shared secret. Leave unset for open access.
BAND_SECRET=

# Optional: use the YouTube Data API instead of HTML scraping.
YOUTUBE_API_KEY=

# ---- Docker / dev ----
# The port the app runs on. Single source of truth: used for the Next.js
# dev server, the production server, the Docker host mapping, the container
# listener, the healthcheck, and EXPOSE. Change this one value everywhere.
PORT=3000
# How many pre-migration DB backups to keep (newest kept, older pruned).
BACKUP_KEEP=10